# Salin file ini ke .env dan isi nilai yang sesuai
# cp .env.example .env

# ── Server ─────────────────────────────────────────────────
PORT=3000

# ── Python Backend ─────────────────────────────────────────
# URL endpoint webhook di backend — kemana pesan WA diteruskan
PYTHON_WEBHOOK_URL=http://localhost:8000/webhook/baileys

# Base URL backend — dipakai saat kirim media (download file sebelum kirim ke WA)
PYTHON_BACKEND_URL=http://localhost:8000

# API key untuk autentikasi ke backend
# Harus sama dengan BAILEYS_API_KEY di backend .env
INTERNAL_API_KEY=baileys-internal-2026
